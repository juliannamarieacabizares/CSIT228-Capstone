<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="300.0" prefWidth="400.0" spacing="20.0" style="-fx-background-color: #BDE8F5;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.group8.csit228capstone.LoginController">
   <padding>
      <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
   </padding>
   <children>
      <Label text="Login" textFill="#0f2854">
         <font>
            <Font name="System Bold" size="32.0" />
         </font>
      </Label>
      <TextField fx:id="textUsername" minWidth="250.0" promptText="Username" style="-fx-background-radius: 5;" />
      <PasswordField fx:id="textPassword" promptText="Password" style="-fx-background-radius: 5;" />
      <Button fx:id="btnSignIn" maxWidth="300.0" mnemonicParsing="false" onAction="#handleLogin" style="-fx-background-color: #1C4D8D;" text="Sign In" textFill="WHITE">
         <font>
            <Font name="System Bold" size="12.0" />
         </font></Button>
   </children>
</VBox>
